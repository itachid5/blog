def dependency_help() -> str:
    return "\n".join(
        [
            "Install missing dependencies with one of:",
            "  apt: sudo apt update && sudo apt install -y curl tar gzip",
            "  apk: sudo apk add --no-cache curl tar gzip",
            "  yum: sudo yum install -y curl tar gzip",
            "  pkg: sudo pkg install -y curl tar gzip",
        ]
    )


def require_tools() -> bool:
    missing = [tool for tool in ("tar", "gzip") if shutil.which(tool) is None]
    if missing:
        print(f"Missing required tools: {', '.join(missing)}")
        print(dependency_help())
        return False
    return True


def app_dir() -> Path:
    APP_DIR.mkdir(parents=True, exist_ok=True)
    return APP_DIR


def machine_id() -> str:
    app_dir()
    if MACHINE_ID_PATH.exists():
        value = MACHINE_ID_PATH.read_text().strip()
        if value:
            return value
    value = str(uuid.uuid4())
    MACHINE_ID_PATH.write_text(value + "\n")
    MACHINE_ID_PATH.chmod(0o600)
    return value


def stable_endpoint_id(api_url: str, token: str, client_id: str, protocol: str, local_port: int) -> str:
    material = "|".join([api_url.rstrip("/"), client_id, protocol, str(local_port)])
    return hashlib.sha256(material.encode("utf-8")).hexdigest()


def shell_quote(value: str) -> str:
    return '"' + value.replace('\\', '\\\\').replace('"', '\\"') + '"'


def shell_unquote(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
        value = value[1:-1]
    return value.replace('\\"', '"').replace('\\\\', '\\')


def write_config(config: dict[str, str]) -> None:
    app_dir()
    lines = [f"{key}={shell_quote(value)}" for key, value in config.items() if value]
    CONFIG_PATH.write_text("\n".join(lines) + ("\n" if lines else ""))
    CONFIG_PATH.chmod(0o600)


def save_config(api_url: str, token: str) -> None:
    config = load_config()
    config["API_URL"] = api_url.rstrip("/")
    config["USER_TOKEN"] = token
    write_config(config)


def endpoint_key(protocol: str, local_port: int) -> str:
    return f"{protocol}-{local_port}"


def strip_options(args: list[str], option_names: set[str]) -> list[str]:
    result: list[str] = []
    i = 0
    while i < len(args):
        if args[i] in option_names:
            i += 2
        else:
            result.append(args[i])
            i += 1
    return result


def endpoint_from_args(args: list[str]) -> tuple[str, int] | None:
    endpoint_args = strip_options([arg for arg in args if arg != "--persist"], {"--tcp-mux"})
    if len(endpoint_args) == 1 and endpoint_args[0] == "rdp":
        raise ValueError(rdp_unsupported_message())
    if len(endpoint_args) != 2 or endpoint_args[0] != "tcp":
        return None
    return "tcp", parse_port(endpoint_args[1])


def parse_tcp_mux_option(args: list[str], local_port: int) -> bool:
    value: str | None = None
    i = 0
    while i < len(args):
        if args[i] == "--tcp-mux":
            if i + 1 >= len(args):
                raise ValueError("--tcp-mux requires true or false")
            value = args[i + 1].lower()
            i += 2
        else:
            i += 1
    if value is None:
        return True
    if value in {"true", "1", "yes", "on"}:
        return True
    if value in {"false", "0", "no", "off"}:
        return False
    raise ValueError("--tcp-mux must be true or false")


def tcp_mux_arg(value: bool) -> str:
    return "true" if value else "false"


def persisted_tcp_mux(protocol: str, local_port: int) -> bool | None:
    for endpoint in background_endpoints():
        if endpoint["protocol"] == protocol and endpoint["port"] == local_port and "tcp_mux" in endpoint:
            return bool(endpoint["tcp_mux"])
    return None


def service_local_port(args: list[str]) -> int:
    service_args = strip_options([arg for arg in args if arg != "--foreground-service"], {"--tcp-mux"})
    if len(service_args) != 1:
        raise ValueError("Invalid tcp service usage.")
    return parse_port(service_args[0])


def frpc_log_path_for(protocol: str, local_port: int, stream: str) -> Path:
    return LOG_DIR / f"{endpoint_key(protocol, local_port)}.frpc.{stream}.log"


def state_path_for(protocol: str, local_port: int) -> Path:
    return APP_DIR / f"state-{endpoint_key(protocol, local_port)}.json"


def pid_path_for(protocol: str, local_port: int) -> Path:
    return APP_DIR / f"nekotunnel-{endpoint_key(protocol, local_port)}.pid"


def log_path_for(protocol: str, local_port: int) -> Path:
    return LOG_DIR / f"{endpoint_key(protocol, local_port)}.log"


def service_name(protocol: str, local_port: int) -> str:
    return f"nekotunnel-{endpoint_key(protocol, local_port)}.service"


def service_path_for(protocol: str, local_port: int) -> Path:
    return SYSTEMD_USER_DIR / service_name(protocol, local_port)


def background_endpoints(config: dict[str, str] | None = None) -> list[dict[str, int | str | bool]]:
    config = config or load_config()
    endpoints: list[dict[str, int | str]] = []
    raw = config.get("BACKGROUND_ENDPOINTS", "")
    if raw:
        try:
            decoded = json.loads(raw)
            if isinstance(decoded, list):
                for endpoint in decoded:
                    if isinstance(endpoint, dict) and endpoint.get("protocol") == "tcp":
                        item = {"protocol": "tcp", "port": parse_port(str(endpoint.get("port")))}
                        if "tcp_mux" in endpoint:
                            item["tcp_mux"] = bool(endpoint.get("tcp_mux"))
                        endpoints.append(item)
        except (json.JSONDecodeError, ValueError):
            pass
    legacy_port = config.get("BACKGROUND_PORT")
    if legacy_port:
        try:
            port = parse_port(legacy_port)
            if not any(endpoint["protocol"] == "tcp" and endpoint["port"] == port for endpoint in endpoints):
                endpoints.append({"protocol": "tcp", "port": port})
        except ValueError:
            pass
    return endpoints


def save_background_endpoint(protocol: str, local_port: int, tcp_mux: bool | None = None) -> None:
    config = load_config()
    endpoints = background_endpoints(config)
    existing = next((endpoint for endpoint in endpoints if endpoint["protocol"] == protocol and endpoint["port"] == local_port), None)
    if existing is None:
        item = {"protocol": protocol, "port": local_port}
        if tcp_mux is not None:
            item["tcp_mux"] = tcp_mux
        endpoints.append(item)
    elif tcp_mux is not None:
        existing["tcp_mux"] = tcp_mux
    config["BACKGROUND_ENDPOINTS"] = json.dumps(endpoints, separators=(",", ":"))
    config.pop("BACKGROUND_PORT", None)
    write_config(config)


def load_config() -> dict[str, str]:
    if not CONFIG_PATH.exists():
        return {}
    config: dict[str, str] = {}
    for line in CONFIG_PATH.read_text().splitlines():
        if not line or line.strip().startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        config[key.strip()] = shell_unquote(value)
    return config


def clear_config() -> None:
    if CONFIG_PATH.exists():
        CONFIG_PATH.unlink()


def mask_token(token: str) -> str:
    if not token:
        return "not configured"
    if len(token) <= 10:
        return token[:3] + "..."
    return token[:7] + "..." + token[-4:]


def save_state(state: dict, path: Path = STATE_PATH) -> None:
    app_dir()
    path.write_text(json.dumps(state, indent=2))
    path.chmod(0o600)


def load_state(path: Path = STATE_PATH) -> dict | None:
    if not path.exists():
        return None
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError:
        return {"error": "state file is not valid JSON"}


def clear_state(path: Path = STATE_PATH) -> None:
    if path.exists():
        path.unlink()


def command_for_port(local_port: int, server_addr: str, server_port: int | str) -> str:
    if local_port == 22:
        return f"SSH command: ssh username@{server_addr} -p {server_port}"
    return f"TCP connect command: connect to {server_addr}:{server_port}"


def frpc_archive_name() -> str:
    system = platform.system().lower()
    machine = platform.machine().lower()
    if system != "linux":
        raise RuntimeError(f"Unsupported OS for automatic frpc download: {platform.system()}")
    if machine in {"x86_64", "amd64"}:
        arch = "amd64"
    elif machine in {"aarch64", "arm64"}:
        arch = "arm64"
    else:
        raise RuntimeError(f"Unsupported CPU architecture for automatic frpc download: {platform.machine()}")
    return f"frp_{FRPC_VERSION}_linux_{arch}.tar.gz"


def request_headers(extra: dict[str, str] | None = None) -> dict[str, str]:
    headers = {"User-Agent": f"nekotunnel/{FRPC_VERSION}", "bypass-tunnel-reminder": "true"}
    if extra:
        headers.update(extra)
    return headers


def download_file(url: str, destination: Path) -> None:
    request = urllib.request.Request(url, headers=request_headers())
    with urllib.request.urlopen(request, timeout=120) as response:
        destination.write_bytes(response.read())


def ensure_frpc(api_url: str) -> Path:
    if not require_tools():
        raise RuntimeError("Missing required dependencies.")

    base_dir = app_dir()
    bin_dir = base_dir / f"frpc-{FRPC_VERSION}"
    frpc_path = bin_dir / "frpc"
    if frpc_path.exists():
        frpc_path.chmod(frpc_path.stat().st_mode | stat.S_IXUSR)
        return frpc_path

    archive_name = frpc_archive_name()
    cache_dir = base_dir / "cache"
    cache_dir.mkdir(parents=True, exist_ok=True)
    archive_path = cache_dir / archive_name
    if not archive_path.exists():
        frpc_url = api_url.rstrip("/") + f"/client/frpc/{archive_name}"
        print(f"Downloading frpc v{FRPC_VERSION} from NekoTunnel Central...", flush=True)
        download_file(frpc_url, archive_path)

    with tempfile.TemporaryDirectory(prefix="nekotunnel-frpc-") as tmp:
        tmp_path = Path(tmp)
        with tarfile.open(archive_path, "r:gz") as archive:
            root = tmp_path.resolve()
            for member in archive.getmembers():
                target = (tmp_path / member.name).resolve()
                if target != root and not str(target).startswith(str(root) + os.sep):
                    raise RuntimeError("Downloaded frpc archive contains an unsafe path.")
            archive.extractall(tmp_path)
        matches = [path for path in tmp_path.rglob("frpc") if path.is_file()]
        if not matches:
            raise RuntimeError("Downloaded frpc archive did not contain an frpc binary.")
        bin_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(matches[0], frpc_path)
    frpc_path.chmod(frpc_path.stat().st_mode | stat.S_IXUSR)
    return frpc_path


def post_json(api_url: str, path: str, payload: dict) -> tuple[int, dict | None, str]:
    url = api_url.rstrip("/") + path
    body = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(url, data=body, headers=request_headers({"Content-Type": "application/json"}), method="POST")
    try:
        with urllib.request.urlopen(request, timeout=15) as response:
            text = response.read().decode("utf-8")
            return response.status, json.loads(text), text
    except urllib.error.HTTPError as exc:
        text = exc.read().decode("utf-8")
        try:
            return exc.code, json.loads(text), text
        except json.JSONDecodeError:
            return exc.code, None, text


def write_frpc_config(config_path: Path, allocation: dict, local_port: int) -> None:
    tcp_mux = bool(allocation.get("tcp_mux", False if local_port == 3389 else True))
    config_path.parent.mkdir(parents=True, exist_ok=True)
    config_path.write_text(
        "\n".join(
            [
                f'serverAddr = "{allocation["server_addr"]}"',
                f'serverPort = {allocation["server_port"]}',
                "",
                "[auth]",
                'method = "token"',
                f'token = "{allocation["frp_token"]}"',
                "",
                "loginFailExit = false",
                "",
                "[transport]",
                "protocol = \"tcp\"",
                "tls.enable = true",
                "tls.serverName = \"nekotunnel-control\"",
                f"tcpMux = {str(tcp_mux).lower()}",
                "tcpMuxKeepaliveInterval = 30",
                "heartbeatInterval = 20",
                "heartbeatTimeout = 120",
                "dialServerKeepalive = 30",
                "",
                "[[proxies]]",
                f'name = "{allocation["proxy_name"]}"',
                'type = "tcp"',
                'localIP = "127.0.0.1"',
                f"localPort = {local_port}",
                f'remotePort = {int(allocation["remote_port"])}',
                "",
            ]
        )
    )
    config_path.chmod(0o600)


def heartbeat_loop(
    api_url: str,
    token: str,
    session_id: str,
    interval: int,
    stop_event: threading.Event,
    state_path: Path | None = None,
) -> None:
    misses = 0
    while not stop_event.wait(interval):
        try:
            status, data, body = post_json(api_url, "/api/heartbeat", {"token": token, "session_id": session_id})
        except Exception as exc:
            misses += 1
            message = f"API heartbeat failure {misses}: {exc}"
            print(message, flush=True)
            if state_path:
                state = load_state(state_path) or {}
                state["last_heartbeat_error"] = message
                save_state(state, state_path)
            continue
        if not data or not data.get("ok"):
            misses += 1
            message = f"API heartbeat degraded {misses} with HTTP {status}: {body}"
            print(message, flush=True)
            if state_path:
                state = load_state(state_path) or {}
                state["last_heartbeat_error"] = message
                save_state(state, state_path)
            continue
        if misses:
            print("API heartbeat recovered", flush=True)
            if state_path:
                state = load_state(state_path) or {}
                state.pop("last_heartbeat_error", None)
                save_state(state, state_path)
        misses = 0


def disconnect(api_url: str, token: str, session_id: str, release: bool = True) -> bool:
    try:
        post_json(api_url, "/api/disconnect", {"token": token, "session_id": session_id, "release": release})
        return True
    except Exception as exc:
        print(f"Disconnect failed: {exc}", flush=True)
        return False


def disconnect_saved_state(path: Path = STATE_PATH) -> bool:
    state = load_state(path)
    if not state or "error" in state:
        return True
    config = load_config()
    api_url = config.get("API_URL", "").rstrip("/")
    token = config.get("USER_TOKEN", "")
    session_id = state.get("session_id")
    if api_url and token and session_id:
        ok = disconnect(api_url, token, str(session_id), release=True)
        if ok:
            clear_state(path)
        return ok
    clear_state(path)
    return True


def parse_login(args: list[str]) -> tuple[str, str] | None:
    if len(args) == 1:
        return DEFAULT_API_URL, args[0]
    if len(args) == 3 and args[1] == "--api":
        return args[2].rstrip("/"), args[0]
    return None


def run_api(args: list[str]) -> int:
    config = load_config()
    if not args:
        print(f"API URL: {config.get('API_URL', DEFAULT_API_URL).rstrip('/')}")
        return 0
    if len(args) == 1:
        config["API_URL"] = args[0].rstrip("/")
        write_config(config)
        print(f"API URL: {config['API_URL']}")
        return 0
    return usage()


def rdp_unsupported_message() -> str:
    return "RDP is not officially supported. Use generic TCP:\nnekotunnel tcp 3389\nor\nnekotunnel start tcp 3389"


def parse_port(value: str) -> int:
    try:
        local_port = int(value)
    except ValueError as exc:
        raise ValueError("local_port must be an integer from 1 to 65535") from exc
    if local_port < 1 or local_port > 65535:
        raise ValueError("local_port must be an integer from 1 to 65535")
    return local_port


def resolve_credentials(args: list[str]) -> tuple[int, str, str, bool]:
    service_args = strip_options([arg for arg in args if arg != "--foreground-service"], {"--tcp-mux"})
    if len(service_args) == 1:
        local_port = parse_port(service_args[0])
        config = load_config()
        api_url = config.get("API_URL", DEFAULT_API_URL).rstrip("/")
        token = config.get("USER_TOKEN", "")
        if not token:
            raise RuntimeError("No token configured. Run: nekotunnel token USER_TOKEN")
        return local_port, token, api_url, parse_tcp_mux_option(args, local_port)
    if len(service_args) == 3:
        local_port = parse_port(service_args[0])
        return local_port, service_args[1], service_args[2].rstrip("/"), parse_tcp_mux_option(args, local_port)
    raise ValueError("Invalid tcp usage.")


def systemd_available() -> bool:
    if shutil.which("systemctl") is None:
        return False
    try:
        result = subprocess.run(["systemctl", "--user", "status"], capture_output=True, text=True, timeout=5)
        output = (result.stdout + result.stderr).lower()
        if "not running" in output or "failed to connect" in output:
            return False
        return result.returncode == 0
    except Exception:
        return False


def service_content(protocol: str, local_port: int) -> str:
    executable = Path.home() / ".local" / "bin" / "nekotunnel"
    return f"""[Unit]
Description=NekoTunnel {protocol} {local_port} background tunnel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={executable} run-service {protocol} {local_port}
Restart=always
RestartSec=5
EnvironmentFile={CONFIG_PATH}
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
"""


def system_service_content(protocol: str, local_port: int, run_user: str) -> str:
    executable = Path.home() / ".local" / "bin" / "nekotunnel"
    return f"""[Unit]
Description=NekoTunnel {protocol} {local_port} system tunnel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={run_user}
ExecStart={executable} run-service {protocol} {local_port}
Restart=always
RestartSec=5
EnvironmentFile={CONFIG_PATH}
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
"""


def run_enable_boot() -> int:
    user = os.environ.get("USER") or os.environ.get("LOGNAME") or "$USER"
    if not shutil.which("loginctl"):
        print(f"loginctl not found. To keep user services running after logout/reboot, run: loginctl enable-linger {user}")
        return 1
    result = subprocess.run(["loginctl", "enable-linger", user], check=False)
    if result.returncode != 0:
        print(f"Could not enable linger. Run: loginctl enable-linger {user}")
        return result.returncode
    print(f"Enabled linger for {user}.")
    return 0


def run_install_system_service(args: list[str]) -> int:
    endpoint_args = []
    run_user = os.environ.get("SUDO_USER") or os.environ.get("USER") or "root"
    i = 0
    while i < len(args):
        if args[i] == "--user" and i + 1 < len(args):
            run_user = args[i + 1]
            i += 2
        else:
            endpoint_args.append(args[i])
            i += 1
    endpoint = endpoint_from_args(endpoint_args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    if hasattr(os, "geteuid") and os.geteuid() != 0:
        print(f"Run as root: sudo nekotunnel install-system-service {protocol} {local_port} --user {run_user}")
        return 1
    tcp_mux = parse_tcp_mux_option(args, local_port)
    save_background_endpoint(protocol, local_port, tcp_mux)
    service_path = Path("/etc/systemd/system") / service_name(protocol, local_port)
    service_path.write_text(system_service_content(protocol, local_port, run_user))
    subprocess.run(["systemctl", "daemon-reload"], check=False)
    result = subprocess.run(["systemctl", "enable", "--now", service_path.name], check=False)
    if result.returncode != 0:
        print(f"Could not start system service {service_path.name}.")
        return result.returncode
    print(f"NekoTunnel system service {service_path.name} installed for {run_user}.")
    return 0


def run_status() -> int:
    config = load_config()
    api_url = config.get("API_URL", DEFAULT_API_URL).rstrip("/")
    user_token = config.get("USER_TOKEN")
    endpoints = background_endpoints(config)
    frpc_path = APP_DIR / f"frpc-{FRPC_VERSION}" / "frpc"
    print(f"API URL: {api_url}")
    print(f"Token: {mask_token(user_token or '')}")
    print(f"Machine ID: {machine_id()[:12]}")
    print(f"frpc v{FRPC_VERSION}: {'installed' if frpc_path.exists() else 'not installed'}")
    print("Background endpoints:")
    if not endpoints:
        print("  none configured")
    for endpoint in endpoints:
        protocol = str(endpoint["protocol"])
        port = int(endpoint["port"])
        key = endpoint_key(protocol, port)
        if systemd_available():
            service_path = service_path_for(protocol, port)
            result = subprocess.run(["systemctl", "--user", "is-active", service_name(protocol, port)], capture_output=True, text=True)
            running = result.stdout.strip() == "active"
            exists = service_path.exists()
            state_label = f"systemd task_exists={'yes' if exists else 'no'} running={'yes' if running else 'no'}"
        else:
            pid_path = pid_path_for(protocol, port)
            pid = pid_path.read_text().strip() if pid_path.exists() else ""
            running = pid.isdigit() and Path(f"/proc/{pid}").exists()
            exists = pid_path.exists()
            state_label = f"nohup task_exists={'yes' if exists else 'no'} running={'yes' if running else 'no'}{f' pid={pid}' if pid else ''}"
        print(f"  {key}: {state_label}")
        state = load_state(state_path_for(protocol, port))
        if state and "error" not in state:
            print(f"    session_id: {state.get('session_id', '-')}")
            print(f"    remote: {state.get('server_addr', '-')}:{state.get('server_port', '-')}")
            print(f"    endpoint_id: {str(state.get('endpoint_id', '-'))[:12]}")
            print(f"    reconnect_count: {state.get('reconnect_count', 0)}")
            print(f"    started_at: {state.get('started_at', '-')}")
            if state.get("last_error"):
                print(f"    last_error: {state.get('last_error')}")
        elif state and "error" in state:
            print(f"    last_error: {state['error']}")
    state = load_state()
    if state:
        print("Foreground session state:")
        if "error" in state:
            print(f"  {state['error']}")
        else:
            print(f"  session_id: {state.get('session_id', '-')}")
            print(f"  local_port: {state.get('local_port', '-')}")
            print(f"  remote: {state.get('server_addr', '-')}:{state.get('server_port', '-')}")
    return 0


def run_tcp_once(args: list[str]) -> int:
    try:
        local_port, user_token, api_url, tcp_mux = resolve_credentials(args)
    except (RuntimeError, ValueError) as exc:
        print(exc)
        return 2

    try:
        frpc_path = ensure_frpc(api_url)
    except Exception as exc:
        print(f"Could not prepare frpc v{FRPC_VERSION}: {exc}")
        return 1

    protocol = "tcp"
    client_id = machine_id()
    endpoint_id = stable_endpoint_id(api_url, user_token, client_id, protocol, local_port)
    state_path = state_path_for(protocol, local_port) if "--foreground-service" in args else STATE_PATH
    status, data, body = post_json(
        api_url,
        "/api/connect",
        {
            "token": user_token,
            "protocol": protocol,
            "local_port": local_port,
            "client_info": f"nekotunnel/{FRPC_VERSION}",
            "client_id": client_id,
            "endpoint_id": endpoint_id,
            "tcp_mux": tcp_mux,
        },
    )
    if not data:
        print(f"Connect failed with HTTP {status}: {body}")
        return 1
    if not data.get("ok"):
        print(json.dumps(data, indent=2))
        return 1

    session_id = data["session_id"]
    config_path = APP_DIR / f"frpc-{session_id}.toml"
    write_frpc_config(config_path, data, local_port)
    previous_state = load_state(state_path) or {}
    public_address = f"{data['server_addr']}:{data['server_port']}"
    previous_public_address = None
    if previous_state.get("server_addr") and previous_state.get("server_port"):
        previous_public_address = f"{previous_state['server_addr']}:{previous_state['server_port']}"
    state_data = {
        "session_id": session_id,
        "slot_id": data.get("slot_id"),
        "protocol": protocol,
        "local_port": local_port,
        "server_addr": data["server_addr"],
        "server_port": data["server_port"],
        "remote_port": data["remote_port"],
        "proxy_name": data["proxy_name"],
        "client_id": data.get("client_id") or client_id,
        "endpoint_id": data.get("endpoint_id") or endpoint_id,
        "reconnect_count": data.get("reconnect_count", 0),
        "tcp_mux": data.get("tcp_mux", tcp_mux),
        "route_mode": data.get("route_mode", "mux"),
        "connection_profile": data.get("connection_profile", "generic"),
        "same_endpoint_reused": previous_state.get("endpoint_id") == (data.get("endpoint_id") or endpoint_id) if previous_state else False,
        "same_slot_reused": previous_state.get("slot_id") == data.get("slot_id") if previous_state else False,
        "public_address_changed": bool(previous_public_address and previous_public_address != public_address),
        "public_address_reused": previous_public_address == public_address if previous_public_address else False,
        "started_at": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    save_state(state_data, state_path)

    print(f"Connected session: {session_id}", flush=True)
    print(f"public_address={data['server_addr']}:{data['server_port']} reconnect_count={state_data['reconnect_count']}", flush=True)
    print(command_for_port(local_port, data["server_addr"], data["server_port"]), flush=True)
    if "--foreground-service" in args:
        print(f"NekoTunnel service mode running. Use `nekotunnel stop {protocol} {local_port}` to stop.", flush=True)
    else:
        print("Press Ctrl+C to disconnect.", flush=True)

    stop_event = threading.Event()
    heartbeat = threading.Thread(
        target=heartbeat_loop,
        args=(api_url, user_token, session_id, int(data.get("heartbeat_interval", 15)), stop_event, state_path),
        daemon=True,
    )
    heartbeat.start()

    stdout_file = None
    stderr_file = None
    if "--foreground-service" in args:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        stdout_file = open(frpc_log_path_for(protocol, local_port, "out"), "ab", buffering=0)
        stderr_file = open(frpc_log_path_for(protocol, local_port, "err"), "ab", buffering=0)
    process = subprocess.Popen([str(frpc_path), "-c", str(config_path)], stdout=stdout_file, stderr=stderr_file)

    def stop(_signum=None, _frame=None):
        global SERVICE_STOPPING
        if "--foreground-service" in args:
            SERVICE_STOPPING = True
        stop_event.set()
        if process.poll() is None:
            process.terminate()

    signal.signal(signal.SIGINT, stop)
    signal.signal(signal.SIGTERM, stop)

    try:
        while process.poll() is None and not stop_event.is_set():
            time.sleep(0.5)
    finally:
        stop()
        try:
            process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait(timeout=5)
        exit_code = process.returncode or 0
        release = "--foreground-service" not in args or SERVICE_STOPPING
        disconnect(api_url, user_token, session_id, release=release)
        if "--foreground-service" in args:
            state_data["frpc_exit_code"] = exit_code
            state_data["last_error"] = f"frpc exited with code {exit_code}"
            state_data["ended_at"] = time.strftime("%Y-%m-%d %H:%M:%S")
            save_state(state_data, state_path)
        else:
            clear_state(state_path)
        if "--foreground-service" in args:
            state_data["last_reconnect_delay_seconds"] = state_data.get("last_reconnect_delay_seconds")
            save_state(state_data, state_path)
            for stream in ("out", "err"):
                path = frpc_log_path_for(protocol, local_port, stream)
                if path.exists():
                    lines = path.read_text(errors="replace").splitlines()[-100:]
                    print(f"last_100_frpc_{stream}:", flush=True)
                    for line in lines:
                        print(line, flush=True)
        if stdout_file:
            stdout_file.close()
        if stderr_file:
            stderr_file.close()
        if config_path.exists():
            config_path.unlink()

    return process.returncode or 0


def run_tcp(args: list[str]) -> int:
    if "--foreground-service" not in args:
        return run_tcp_once(args)

    stop_requested = False
    backoffs = [2, 5, 10, 20, 30, 60]
    backoff_index = 0

    def request_stop(_signum=None, _frame=None):
        nonlocal stop_requested
        stop_requested = True
        raise StopRequested()

    signal.signal(signal.SIGINT, request_stop)
    signal.signal(signal.SIGTERM, request_stop)
    while not stop_requested:
        started = time.monotonic()
        try:
            code = run_tcp_once(args)
            if stop_requested or SERVICE_STOPPING:
                return code
            if time.monotonic() - started >= 120:
                backoff_index = 0
            delay = backoffs[min(backoff_index, len(backoffs) - 1)]
            jitter = min(3, delay * 0.2) * (0.5 - (time.time() % 1))
            wait_for = max(1, delay + jitter)
            state_path = state_path_for("tcp", service_local_port(args))
            state = load_state(state_path) or {}
            state["last_reconnect_delay_seconds"] = round(wait_for, 1)
            state["last_error"] = f"frpc exited with code {code}"
            save_state(state, state_path)
            print(f"Tunnel exited with code {code}. Reconnecting in {wait_for:.1f} seconds...", flush=True)
            backoff_index = min(backoff_index + 1, len(backoffs) - 1)
            time.sleep(wait_for)
        except StopRequested:
            return 0
        except Exception as exc:
            if stop_requested:
                return 0
            delay = backoffs[min(backoff_index, len(backoffs) - 1)]
            print(f"Tunnel failed: {exc}. Reconnecting in {delay} seconds...", flush=True)
            backoff_index = min(backoff_index + 1, len(backoffs) - 1)
            time.sleep(delay)
    return 0


def run_service(args: list[str]) -> int:
    endpoint = endpoint_from_args(args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    app_dir()
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_path = log_path_for(protocol, local_port)
    mux = parse_tcp_mux_option(args, local_port) if "--tcp-mux" in args else persisted_tcp_mux(protocol, local_port)
    if mux is None:
        mux = False if local_port == 3389 else True
    run_args = [str(local_port), "--foreground-service", "--tcp-mux", tcp_mux_arg(mux)]
    with open(log_path, "ab", buffering=0) as log_file:
        os.dup2(log_file.fileno(), 1)
        os.dup2(log_file.fileno(), 2)
        print(f"started_at={time.strftime('%Y-%m-%d %H:%M:%S')} endpoint={endpoint_key(protocol, local_port)} tcpMux={tcp_mux_arg(mux)}", flush=True)
        return run_tcp(run_args)


def remove_background_endpoint(protocol: str, local_port: int) -> None:
    config = load_config()
    endpoints = [
        endpoint
        for endpoint in background_endpoints(config)
        if not (endpoint["protocol"] == protocol and endpoint["port"] == local_port)
    ]
    config["BACKGROUND_ENDPOINTS"] = json.dumps(endpoints, separators=(",", ":"))
    config.pop("BACKGROUND_PORT", None)
    write_config(config)


def run_start(args: list[str]) -> int:
    endpoint = endpoint_from_args(args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    tcp_mux = parse_tcp_mux_option(args, local_port)
    save_background_endpoint(protocol, local_port, tcp_mux)
    if systemd_available():
        service_path = service_path_for(protocol, local_port)
        service_path.parent.mkdir(parents=True, exist_ok=True)
        service_path.write_text(service_content(protocol, local_port))
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
        result = subprocess.run(["systemctl", "--user", "enable", "--now", service_name(protocol, local_port)], check=False)
        if result.returncode != 0:
            print(f"Could not start systemd user service {service_name(protocol, local_port)}.")
            return result.returncode
        print(f"NekoTunnel background service {service_name(protocol, local_port)} started.")
        print("Use: nekotunnel status")
        print(f"Use: nekotunnel logs {protocol} {local_port}")
        if shutil.which("loginctl"):
            print(f"To keep running after logout, run: loginctl enable-linger {os.environ.get('USER', '$USER')}")
        return 0

    executable = Path.home() / ".local" / "bin" / "nekotunnel"
    log_path = log_path_for(protocol, local_port)
    pid_path = pid_path_for(protocol, local_port)
    app_dir()
    log_file = open(log_path, "ab")
    process = subprocess.Popen(
        [str(executable), "run-service", protocol, str(local_port), "--tcp-mux", str(tcp_mux).lower()],
        stdout=log_file,
        stderr=subprocess.STDOUT,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )
    pid_path.write_text(str(process.pid))
    print(f"NekoTunnel background process {endpoint_key(protocol, local_port)} started with PID {process.pid}.")
    print("Use: nekotunnel status")
    print(f"Use: nekotunnel logs {protocol} {local_port}")
    return 0


def stop_nohup(protocol: str, local_port: int) -> bool:
    pid_path = pid_path_for(protocol, local_port)
    if not pid_path.exists():
        return False
    pid_text = pid_path.read_text().strip()
    if pid_text.isdigit():
        try:
            os.kill(int(pid_text), signal.SIGTERM)
            for _ in range(20):
                if not Path(f"/proc/{pid_text}").exists():
                    break
                time.sleep(0.25)
            if Path(f"/proc/{pid_text}").exists():
                os.kill(int(pid_text), signal.SIGKILL)
        except ProcessLookupError:
            pass
    pid_path.unlink(missing_ok=True)
    return True


def stop_endpoint(protocol: str, local_port: int, remove_config: bool = True) -> bool:
    stopped = False
    if systemd_available():
        result = subprocess.run(["systemctl", "--user", "stop", service_name(protocol, local_port)], check=False)
        stopped = result.returncode == 0
    if stop_nohup(protocol, local_port):
        stopped = True
    disconnect_saved_state(state_path_for(protocol, local_port))
    if remove_config:
        remove_background_endpoint(protocol, local_port)
    return stopped


def run_stop(args: list[str]) -> int:
    if args == ["all"] or not args:
        endpoints = background_endpoints()
        if not endpoints:
            print("No background endpoints configured.")
            return 0
        any_stopped = False
        for endpoint in endpoints:
            protocol = str(endpoint["protocol"])
            local_port = int(endpoint["port"])
            if stop_endpoint(protocol, local_port):
                any_stopped = True
                print(f"Stopped {endpoint_key(protocol, local_port)}.")
            else:
                print(f"{endpoint_key(protocol, local_port)} was not running.")
        return 0 if any_stopped or endpoints else 0

    endpoint = endpoint_from_args(args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    if stop_endpoint(protocol, local_port):
        print(f"NekoTunnel background endpoint {endpoint_key(protocol, local_port)} stopped.")
    else:
        print(f"NekoTunnel background endpoint {endpoint_key(protocol, local_port)} was not running.")
    return 0


def run_restart(args: list[str]) -> int:
    endpoint = endpoint_from_args(args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    stop_endpoint(protocol, local_port, remove_config=False)
    return run_start([protocol, str(local_port)])


