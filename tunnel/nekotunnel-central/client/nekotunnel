def last_log_line(path: Path) -> str:
    if not path.exists():
        return "-"
    lines = [line for line in path.read_text(errors="replace").splitlines() if line.strip()]
    return lines[-1] if lines else "-"


def print_recent(path: Path, label: str, tail: int = 100) -> None:
    print(f"==> {label} ({path}) <==")
    if path.exists():
        print("\n".join(path.read_text(errors="replace").splitlines()[-tail:]))
    else:
        print("No log file yet.")


def run_logs(args: list[str]) -> int:
    if not args:
        print("Usage: nekotunnel logs <all|tcp <local_port>> [--frpc|--report]")
        print("Try: nekotunnel logs all")
        print("Try: nekotunnel logs tcp 3389")
        return 2
    if args == ["all"]:
        endpoints = background_endpoints()
        if not endpoints:
            print("No background endpoints configured.")
            return 0
        for endpoint in endpoints:
            protocol = str(endpoint["protocol"])
            local_port = int(endpoint["port"])
            path = log_path_for(protocol, local_port)
            print(f"==> {endpoint_key(protocol, local_port)} ({path}) <==")
            if path.exists():
                print(path.read_text(errors="replace"))
            else:
                print("No log file yet.")
        return 0

    endpoint = endpoint_from_args(args)
    if endpoint is None:
        return usage()
    protocol, local_port = endpoint
    if systemd_available() and service_path_for(protocol, local_port).exists():
        return subprocess.call(["journalctl", "--user", "-u", service_name(protocol, local_port), "-f"])
    log_path = log_path_for(protocol, local_port)
    log_path.touch(exist_ok=True)
    return subprocess.call(["tail", "-f", str(log_path)])


def main() -> int:
    args = sys.argv[1:]
    if not args:
        return usage()

    command = args[0]
    if command in {"token", "login"}:
        parsed = parse_login(args[1:])
        if not parsed:
            return usage()
        api_url, token = parsed
        save_config(api_url, token)
        print(f"Saved NekoTunnel config for {api_url} with token {mask_token(token)}")
        return 0
    if command == "tcp":
        return run_tcp(args[1:])
    if command == "rdp":
        print(rdp_unsupported_message())
        return 2
    if command == "api":
        return run_api(args[1:])
    if command == "start":
        return run_start(args[1:])
    if command == "run-service":
        return run_service(args[1:])
    if command == "install-service":
        return run_start(args[1:])
    if command == "install-system-service":
        return run_install_system_service(args[1:])
    if command == "enable-boot":
        if len(args) != 1:
            return usage()
        return run_enable_boot()
    if command == "stop":
        return run_stop(args[1:])
    if command == "restart":
        return run_restart(args[1:])
    if command == "status":
        if len(args) != 1:
            return usage()
        return run_status()
    if command == "logs":
        return run_logs(args[1:])
    if command == "logout":
        if len(args) != 1:
            return usage()
        clear_config()
        print("Removed NekoTunnel config.")
        return 0
    return usage()


if __name__ == "__main__":
    raise SystemExit(main())
